{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "env": {
      "NIXPACKS_PKGS": "nodejs_20 python311 gcc",
      "NIXPACKS_PYTHON_VENV": "/opt/venv"
    }
  },
  "deploy": {
    "startCommand": "PATH=\"/opt/venv/bin:$PATH\" uvicorn backend.app.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
